---
const AVAILABLE = true;
const STATUS_LABEL = "Available for work";
---

<div class="corner-contact mono" id="contact">
  {AVAILABLE && (
    <span class="status" aria-label={STATUS_LABEL}>
      <span class="dot" aria-hidden="true"></span>
      <span class="status-label">{STATUS_LABEL}</span>
    </span>
  )}
  <a href="mailto:nicole.deschamps1@gmail.com" class="link-underline">nicole.deschamps1@gmail.com</a>
  <a href="https://github.com/nicoledeschamps1-crypto" target="_blank" rel="noopener" class="link-underline">github</a>
  <a href="https://instagram.com/huesofsaturn" target="_blank" rel="noopener" class="link-underline">instagram</a>
</div>

<style>
  .corner-contact {
    position: fixed;
    bottom: max(20px, env(safe-area-inset-bottom));
    right: 32px;
    display: flex;
    align-items: center;
    gap: 18px;
    z-index: 50;
    color: var(--ink-soft);
  }
  .corner-contact a {
    padding: 8px 2px;
    margin: -8px 0;
  }
  .corner-contact a:hover { color: var(--ink); }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2f9e6e;
    box-shadow: 0 0 0 0 rgba(47, 158, 110, 0.55);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(47, 158, 110, 0.55); }
    50%      { box-shadow: 0 0 0 6px rgba(47, 158, 110, 0); }
  }

  @media (max-width: 640px) {
    .corner-contact {
      bottom: max(14px, env(safe-area-inset-bottom));
      right: 18px;
      gap: 14px;
      font-size: 10px;
    }
    .status-label { display: none; }
    /* On phones drop github+instagram from the contact rail to keep it on one short line — they're still in the resume's tail link list and accessible from the wordmark page */
    .corner-contact a:not([href^="mailto:"]) { display: none; }
    .corner-contact a {
      padding: 12px 4px;
      margin: -12px 0;
    }
  }
</style>
