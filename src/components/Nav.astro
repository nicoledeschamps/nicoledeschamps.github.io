---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = base || "/";
const resumeHref = `${base}/resume`;
---

<nav class="nav">
  <a href={home} class="wordmark" aria-label="HUES — home">
    <span class="ring" aria-hidden="true"></span>
    <span class="word">HUES</span>
  </a>
  <div class="active mono" id="active-project" aria-live="polite"></div>
  <div class="links mono">
    <a href={resumeHref} class="link-underline">resume</a>
    <a href="mailto:nicole.deschamps1@gmail.com" class="link-underline">contact</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 20px 32px;
    padding-top: max(20px, env(safe-area-inset-top));
    z-index: 100;
    gap: 24px;
    isolation: isolate;
  }
  .nav::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(245, 243, 238, 0.92) 0, rgba(245, 243, 238, 0.88) 60%, rgba(245, 243, 238, 0));
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    mask-image: linear-gradient(to bottom, #000 60%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, #000 60%, transparent);
    z-index: -1;
    pointer-events: none;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    letter-spacing: 0.02em;
    line-height: 1;
    justify-self: start;
  }
  .ring {
    width: 14px;
    height: 14px;
    border: 1px solid currentColor;
    border-radius: 50%;
    position: relative;
  }
  .ring::before {
    content: "";
    position: absolute;
    inset: -3px -6px;
    border: 1px solid currentColor;
    border-radius: 50%;
    transform: rotate(-18deg);
    opacity: 0.55;
  }
  .word {
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .active {
    justify-self: center;
    text-align: center;
    min-width: 0;
    max-width: 100%;
    min-height: 1em;
    opacity: 0.85;
    transition: opacity 0.5s var(--ease);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .links {
    display: flex;
    gap: 24px;
    justify-self: end;
  }
  .links a {
    padding: 8px 2px;
    margin: -8px 0;
  }

  @media (max-width: 640px) {
    .nav {
      padding: 14px 18px;
      padding-top: max(14px, env(safe-area-inset-top));
      grid-template-columns: auto auto;
      justify-content: space-between;
      gap: 12px;
    }
    .active { display: none; }
    .links { gap: 16px; }
    .links a { padding: 10px 4px; }
  }
</style>
